From dd6a0ac0ba8d0f2f2d2e628dcebf6d3f565df34e Mon Sep 17 00:00:00 2001
From: Jonathan Billings <jbilling@redhat.com>
Date: Mon, 20 Apr 2026 11:37:06 -0400
Subject: [PATCH] Remove the github.com/mailru/easyjson Go library

The easyjson library is brought in as part of the CrowdSec Go
library, so it is not needed in the client.

VK/Mail.ru is a sanctioned Russian entity and we want to eliminate
any chance of there being a supply-chain attack.
---
 go.mod | 1 -
 go.sum | 2 --
 2 files changed, 3 deletions(-)

diff --git a/go.mod b/go.mod
index 5172b1a78..25f501f96 100644
--- a/go.mod
+++ b/go.mod
@@ -240,7 +240,6 @@ require (
 	github.com/libdns/libdns v0.2.2 // indirect
 	github.com/lufia/plan9stats v0.0.0-20240513124658-fba389f38bae // indirect
 	github.com/magiconair/properties v1.8.10 // indirect
-	github.com/mailru/easyjson v0.9.0 // indirect
 	github.com/mattermost/xml-roundtrip-validator v0.1.0 // indirect
 	github.com/mattn/go-sqlite3 v1.14.32 // indirect
 	github.com/mdelapenya/tlscert v0.2.0 // indirect
diff --git a/go.sum b/go.sum
index 9293ce73b..5bbc31ae6 100644
--- a/go.sum
+++ b/go.sum
@@ -400,8 +400,6 @@ github.com/lufia/plan9stats v0.0.0-20240513124658-fba389f38bae h1:dIZY4ULFcto4tA
